{
  "discord": {
    "application_id": "YOUR_DISCORD_APPLICATION_ID",
    "user_id": "YOUR_DISCORD_USER_ID",
    "bot_token": "YOUR_DISCORD_BOT_TOKEN",
    "image_webhook_url": ""
  },
  "spotify": {
    "client_id": "YOUR_SPOTIFY_CLIENT_ID",
    "client_secret": "YOUR_SPOTIFY_CLIENT_SECRET",
    "redirect_uri": "http://127.0.0.1:8888/callback",
    "refresh_token": ""
  },
  "lastfm": {
    "_comment": "Only used if NOWPLAYING_SOURCE=lastfm (see HOSTING.md). Needed if the Spotify app owner doesn't have Premium -- Spotify's Feb 2026 policy 403s Development Mode apps on Free accounts.",
    "api_key": "YOUR_LASTFM_API_KEY",
    "username": "YOUR_LASTFM_USERNAME"
  },
  "options": {
    "poll_interval_seconds": 3,
    "tick_interval_seconds": 0.25,
    "min_patch_interval_seconds": 0.5,
    "rate_limit_reserve": 2,
    "log_rate_limits": true,
    "heartbeat_seconds": 0,
    "username_format": "{track} — {artist}",
    "no_lyrics_text": "♪",
    "instrumental_text": "♪ Instrumental ♪",
    "show_when_paused": true
  }
}
